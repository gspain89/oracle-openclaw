---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';

let data: any = { meta: {}, models: [] };
try {
  const raw = readFileSync(resolve(process.cwd(), '..', 'results', 'normalized', 'leaderboard.json'), 'utf-8');
  data = JSON.parse(raw);
} catch {}

const models = data.models;
const scored = models.filter((m: any) => m.scores?.composite);

const efficiency = scored
  .map((m: any) => ({
    name: m.name,
    score: m.scores.composite.best,
    pinch: m.scores.pinchbench?.best || 0,
    ko: m.scores.clawbench_ko?.best || 0,
    cost: m.cost_per_run_usd,
    free: m.free,
    efficiency: m.cost_per_run_usd === 0
      ? Infinity
      : m.scores.composite.best / m.cost_per_run_usd,
  }))
  .sort((a: any, b: any) => b.efficiency - a.efficiency);

const scatterData = JSON.stringify(scored.map((m: any) => ({
  name: m.name,
  x: m.cost_per_run_usd,
  y: m.scores.composite.best,
  free: m.free,
})));
---

<Layout title="비용 효율">
  <div class="page-header">
    <h1>Cost <span class="accent">Efficiency</span></h1>
    <p>성능 대비 비용이 가장 효율적인 모델 순위</p>
  </div>

  {scored.length > 0 ? (
    <div class="cost-grid">
      <div class="card chart-card">
        <h3>성능 vs 비용</h3>
        <p class="chart-desc">X축: 실행 비용(USD/회), Y축: 종합 점수. 좌상단이 최적</p>
        <div class="chart-wrap">
          <canvas id="scatter-chart" height="320"></canvas>
        </div>
      </div>

      <div class="card efficiency-card">
        <h3>비용 효율 순위</h3>
        <div class="eff-list">
          {efficiency.map((m: any, i: number) => {
            const maxFiniteEff = efficiency.find((e: any) => e.efficiency !== Infinity)?.efficiency || 1;
            const barW = m.efficiency === Infinity ? 100 : Math.min((m.efficiency / maxFiniteEff) * 100, 100);
            return (
              <div class="eff-row">
                <span class="eff-rank">{i + 1}</span>
                <div class="eff-info">
                  <span class="eff-name">
                    {m.name}
                    {m.free && <span class="free-tag">FREE</span>}
                  </span>
                  <span class="eff-detail">
                    {m.cost === 0
                      ? `${m.score.toFixed(1)}점 / 무료`
                      : `${m.score.toFixed(1)}점 / $${m.cost.toFixed(2)} / ${m.efficiency.toFixed(0)}점/$`}
                  </span>
                </div>
                <div class="eff-bar-track">
                  <div class="eff-bar-fill" style={`width:${barW.toFixed(1)}%`}></div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  ) : (
    <div class="card">
      <div class="empty-state">
        <div class="icon">$</div>
        <h3>비용 효율 데이터 없음</h3>
        <p>벤치마크 결과가 수집되면 비용 효율 분석이 표시됩니다.</p>
      </div>
    </div>
  )}
</Layout>

<style>
  .cost-grid {
    display: grid; grid-template-columns: 1.2fr 0.8fr;
    gap: 20px;
    animation: fade-up 0.5s var(--ease-out-expo) backwards;
  }
  @media (max-width: 768px) { .cost-grid { grid-template-columns: 1fr; } }
  .chart-wrap { margin-top: 16px; }
  .chart-desc { font-size: 0.8rem; color: var(--text-3); margin-top: 4px; }
  .eff-list { display: flex; flex-direction: column; gap: 16px; margin-top: 18px; }
  .eff-row {
    display: grid; grid-template-columns: 28px 1fr 100px;
    align-items: center; gap: 12px;
  }
  .eff-rank {
    font-family: var(--font-mono); font-weight: 600;
    font-size: 0.85rem; color: var(--text-3); text-align: center;
  }
  .eff-info { display: flex; flex-direction: column; gap: 3px; }
  .eff-name { font-size: 0.88rem; font-weight: 600; color: var(--text); display: flex; align-items: center; gap: 8px; }
  .eff-detail { font-size: 0.72rem; color: var(--text-2); font-family: var(--font-mono); }
  .eff-bar-track {
    height: 7px; background: var(--bg-track);
    border-radius: 4px; overflow: hidden;
  }
  .eff-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--bar-avg));
    border-radius: 4px;
  }
</style>

<script is:inline define:vars={{ scatterData }}>
  document.addEventListener('DOMContentLoaded', function() {
    var points = JSON.parse(scatterData);
    var ctx = document.getElementById('scatter-chart');
    if (!ctx || !points.length) return;

    var freeColor = '#2d7a3e';
    var paidColor = '#b8860b';

    new Chart(ctx, {
      type: 'scatter',
      data: {
        datasets: [{
          label: '모델',
          data: points.map(function(p) { return { x: p.x, y: p.y, name: p.name, free: p.free }; }),
          backgroundColor: points.map(function(p) { return p.free ? freeColor : paidColor; }),
          borderColor: points.map(function(p) { return p.free ? '#1a5c2e' : '#8a6a08'; }),
          borderWidth: 2,
          pointRadius: 8,
          pointHoverRadius: 11,
        }]
      },
      options: {
        responsive: true,
        scales: {
          x: {
            title: { display: true, text: '비용 (USD/회)', color: '#6b5e50', font: { family: 'Noto Sans KR', size: 12 } },
            ticks: { color: '#9e9082', font: { family: 'IBM Plex Mono', size: 11 }, callback: function(v) { return '$' + v; } },
            grid: { color: 'rgba(120,100,70,0.08)' },
            border: { color: 'rgba(120,100,70,0.15)' },
          },
          y: {
            title: { display: true, text: '종합 점수', color: '#6b5e50', font: { family: 'Noto Sans KR', size: 12 } },
            min: 0, max: 100,
            ticks: { color: '#9e9082', font: { family: 'IBM Plex Mono', size: 11 } },
            grid: { color: 'rgba(120,100,70,0.08)' },
            border: { color: 'rgba(120,100,70,0.15)' },
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: 'rgba(26,20,16,0.92)',
            titleColor: '#f0ead8',
            bodyColor: '#f0ead8',
            borderColor: 'rgba(120,100,70,0.3)',
            borderWidth: 1,
            bodyFont: { family: 'IBM Plex Mono' },
            callbacks: {
              title: function(items) { return items[0].raw.name; },
              label: function(item) {
                var d = item.raw;
                return [
                  '종합: ' + d.y.toFixed(1) + '점',
                  '비용: ' + (d.x === 0 ? '무료' : '$' + d.x.toFixed(2) + '/회'),
                ];
              }
            }
          }
        },
        animation: { duration: 800, easing: 'easeOutCubic' },
      },
      plugins: [{
        afterDatasetsDraw: function(chart) {
          var ctx2 = chart.ctx;
          ctx2.font = '500 11px "Noto Sans KR"';
          ctx2.textAlign = 'center';
          ctx2.fillStyle = '#1a1410';
          chart.getDatasetMeta(0).data.forEach(function(pt, i) {
            var d = chart.data.datasets[0].data[i];
            ctx2.fillText(d.name, pt.x, pt.y - 14);
          });
        }
      }]
    });
  });
</script>
