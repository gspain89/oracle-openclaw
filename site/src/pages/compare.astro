---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';

let data: any = { meta: {}, models: [] };
try {
  const raw = readFileSync(resolve(process.cwd(), '..', 'results', 'normalized', 'leaderboard.json'), 'utf-8');
  data = JSON.parse(raw);
} catch {}

const models = data.models;
const modelsJson = JSON.stringify(models);
---

<Layout title="모델 비교">
  <div class="page-header">
    <h1>Model <span class="accent">Comparison</span></h1>
    <p>두 모델의 벤치마크 결과를 나란히 비교</p>
  </div>

  {models.length >= 2 ? (
    <div class="compare-selectors">
      <div class="field-group">
        <label class="field-label" for="model-a">모델 A</label>
        <select id="model-a">
          {models.map((m: any, i: number) => <option value={i} selected={i === 0}>{m.name}</option>)}
        </select>
      </div>
      <div class="compare-vs">VS</div>
      <div class="field-group">
        <label class="field-label" for="model-b">모델 B</label>
        <select id="model-b">
          {models.map((m: any, i: number) => <option value={i} selected={i === 1}>{m.name}</option>)}
        </select>
      </div>
    </div>

    <div class="compare-grid">
      <div class="card radar-card">
        <h3>PinchBench</h3>
        <div class="radar-wrap">
          <canvas id="radar-pb"></canvas>
        </div>
      </div>
      <div class="card bar-card">
        <h3>PinchBench 카테고리</h3>
        <div id="cat-bars-pb" class="cat-bars"></div>
      </div>
      <div class="card radar-card">
        <h3>ClawBench-KO</h3>
        <div class="radar-wrap">
          <canvas id="radar-ko"></canvas>
        </div>
      </div>
      <div class="card bar-card">
        <h3>ClawBench-KO 카테고리</h3>
        <div id="cat-bars-ko" class="cat-bars"></div>
      </div>
    </div>

    <div class="card detail-card">
      <h3>상세 비교</h3>
      <table class="detail-table" id="detail-table">
        <thead>
          <tr><th class="dt-label">항목</th><th id="th-a">모델 A</th><th id="th-b">모델 B</th></tr>
        </thead>
        <tbody id="detail-body"></tbody>
      </table>
    </div>
  ) : (
    <div class="card">
      <div class="empty-state">
        <div class="icon">VS</div>
        <h3>비교할 모델이 없습니다</h3>
        <p>벤치마크 결과가 2개 이상 수집되면 모델 비교가 가능합니다.</p>
      </div>
    </div>
  )}
</Layout>

<style is:global>
  .compare-selectors {
    display: flex; align-items: flex-end; gap: 20px;
    margin-bottom: 28px;
    animation: fade-up 0.5s var(--ease-out-expo) backwards;
  }
  .compare-vs {
    font-family: var(--font-display); font-size: 1.3rem;
    padding-bottom: 11px; color: var(--text-3);
  }
  .compare-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 16px; margin-bottom: 20px;
    animation: fade-up 0.5s var(--ease-out-expo) 0.1s backwards;
    align-items: start;
  }
  .radar-card { padding-bottom: 8px; }
  .bar-card { display: flex; flex-direction: column; justify-content: center; }
  .detail-card { animation: fade-up 0.5s var(--ease-out-expo) 0.2s backwards; }
  .card-sub { font-size: 0.72rem; color: var(--text-3); margin: 2px 0 0; }

  @media (max-width: 768px) {
    .compare-selectors { flex-direction: column; align-items: stretch; }
    .compare-vs { text-align: center; padding: 0; }
    .compare-grid { grid-template-columns: 1fr; }
  }

  .radar-wrap { margin-top: 8px; display: flex; justify-content: center; }

  /* 카테고리 바 */
  .cat-bars { display: flex; flex-direction: column; gap: 12px; margin-top: 14px; }
  .cb-group-label {
    font-family: var(--font-mono); font-size: 0.62rem; font-weight: 700;
    color: var(--accent); text-transform: uppercase; letter-spacing: 0.06em;
    margin-bottom: 4px; margin-top: 6px;
  }
  .cb-row { display: flex; flex-direction: column; gap: 3px; }
  .cb-label {
    font-size: 0.72rem; font-weight: 600; color: var(--text-2);
  }
  .cb-track {
    display: flex; gap: 3px; height: 22px; align-items: center;
  }
  .cb-fill {
    height: 100%; border-radius: 4px; min-width: 2px;
    display: flex; align-items: center; justify-content: flex-end;
    padding: 0 6px;
    font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700;
    color: white; transition: width 0.4s ease;
  }
  .cb-fill.a { background: #8c2416; }
  .cb-fill.b { background: #2563a8; }
  .cb-spacer { flex: 1; }
  .cb-winner { box-shadow: 0 0 0 1.5px currentColor; }

  /* 상세 테이블 */
  .detail-table { width: 100%; margin-top: 14px; }
  .detail-table th, .detail-table td {
    padding: 7px 12px; font-size: 0.78rem;
  }
  .dt-label { width: 180px; }
  .detail-table td:first-child {
    color: var(--text-2); font-size: 0.74rem;
  }
  .winner { color: var(--accent); font-weight: 700; }
  .dt-section {
    font-family: var(--font-mono); font-size: 0.62rem; font-weight: 700;
    color: var(--accent); text-transform: uppercase; letter-spacing: 0.06em;
    padding-top: 10px !important;
    border-top: 1px solid var(--border);
  }
  .dt-section td { border-top: 1px solid var(--border); }
</style>

<script is:inline define:vars={{ modelsJson }}>
  document.addEventListener('DOMContentLoaded', function() {
    var models = JSON.parse(modelsJson);
    var selA = document.getElementById('model-a');
    var selB = document.getElementById('model-b');
    var radarPB = null;
    var radarKO = null;

    var PB_CATS = [
      { id: 'understanding', label: '이해/기억' },
      { id: 'research', label: '조사/분석' },
      { id: 'creation', label: '생성/작문' },
      { id: 'execution', label: '실행/코딩' },
      { id: 'basic', label: '기본/관리' },
    ];
    var KO_CATS = [
      { id: 'data_processing', label: '데이터 처리' },
      { id: 'document_generation', label: '문서 생성' },
      { id: 'korean_system', label: '한국 시스템' },
    ];

    function getCat(m, bench, catId) {
      var s = m.scores[bench];
      if (!s || !s.categories) return 0;
      return s.categories[catId] || 0;
    }
    function getScore(m, bench, field) {
      var s = m.scores[bench];
      return s ? (s[field] || 0) : 0;
    }

    function update() {
      var a = models[+selA.value] || null;
      var b = models[+selB.value] || null;

      /* ── 레이더 공통 옵션 ── */
      var radarOpts = {
        responsive: true,
        maintainAspectRatio: true,
        scales: {
          r: {
            beginAtZero: true, max: 100,
            ticks: { stepSize: 25, color: '#9e9082', font: { family: 'IBM Plex Mono', size: 11 }, backdropColor: 'transparent' },
            grid: { color: 'rgba(120,100,70,0.1)' },
            angleLines: { color: 'rgba(120,100,70,0.1)' },
            pointLabels: { color: '#4a3f35', font: { family: 'Noto Sans KR', size: 13, weight: '600' } },
          }
        },
        plugins: {
          legend: { labels: { color: '#4a3f35', font: { family: 'Noto Sans KR', size: 12, weight: '500' }, usePointStyle: true, pointStyle: 'circle' } },
          tooltip: {
            backgroundColor: 'rgba(26,20,16,0.92)',
            titleColor: '#f0ead8', bodyColor: '#f0ead8',
            titleFont: { family: 'Noto Sans KR', size: 13 },
            bodyFont: { family: 'IBM Plex Mono', size: 13 },
            borderColor: 'rgba(120,100,70,0.3)', borderWidth: 1,
            callbacks: { label: function(c) { return c.dataset.label + ': ' + c.parsed.r.toFixed(1) + '%'; } }
          }
        },
        animation: { duration: 500, easing: 'easeOutCubic' },
      };
      function makeDS(model, color, fill) {
        return {
          label: model ? model.name : '—',
          data: [],
          backgroundColor: fill,
          borderColor: color,
          borderWidth: 2.5,
          pointBackgroundColor: color,
          pointBorderColor: '#fff',
          pointBorderWidth: 1.5,
          pointRadius: 4,
        };
      }

      /* ── PinchBench 레이더 (5축) ── */
      var dsA_pb = makeDS(a, '#8c2416', 'rgba(140,36,22,0.12)');
      dsA_pb.data = PB_CATS.map(function(c) { return a ? getCat(a, 'pinchbench', c.id) : 0; });
      var dsB_pb = makeDS(b, '#2563a8', 'rgba(37,99,168,0.12)');
      dsB_pb.data = PB_CATS.map(function(c) { return b ? getCat(b, 'pinchbench', c.id) : 0; });

      if (radarPB) radarPB.destroy();
      radarPB = new Chart(document.getElementById('radar-pb'), {
        type: 'radar',
        data: { labels: PB_CATS.map(function(c){return c.label;}), datasets: [dsA_pb, dsB_pb] },
        options: radarOpts,
      });

      /* ── ClawBench-KO 레이더 (3축) ── */
      var dsA_ko = makeDS(a, '#8c2416', 'rgba(140,36,22,0.12)');
      dsA_ko.data = KO_CATS.map(function(c) { return a ? getCat(a, 'clawbench_ko', c.id) : 0; });
      var dsB_ko = makeDS(b, '#2563a8', 'rgba(37,99,168,0.12)');
      dsB_ko.data = KO_CATS.map(function(c) { return b ? getCat(b, 'clawbench_ko', c.id) : 0; });

      if (radarKO) radarKO.destroy();
      radarKO = new Chart(document.getElementById('radar-ko'), {
        type: 'radar',
        data: { labels: KO_CATS.map(function(c){return c.label;}), datasets: [dsA_ko, dsB_ko] },
        options: radarOpts,
      });

      /* ── 카테고리별 바 (PB/KO 분리) ── */
      function renderBars(el, cats, bench) {
        var bh = '';
        cats.forEach(function(c) {
          var sa = a ? getCat(a, bench, c.id) : 0;
          var sb = b ? getCat(b, bench, c.id) : 0;
          var wa = sa > sb && sa > 0 ? ' cb-winner' : '';
          var wb = sb > sa && sb > 0 ? ' cb-winner' : '';
          bh += '<div class="cb-row"><span class="cb-label">' + c.label + '</span>' +
            '<div class="cb-track">' +
            '<div class="cb-fill a' + wa + '" style="width:' + (sa*0.45) + '%">' + (sa > 5 ? sa.toFixed(1) : '') + '</div>' +
            '<div class="cb-fill b' + wb + '" style="width:' + (sb*0.45) + '%">' + (sb > 5 ? sb.toFixed(1) : '') + '</div>' +
            '<div class="cb-spacer"></div></div></div>';
        });
        el.innerHTML = bh;
      }
      renderBars(document.getElementById('cat-bars-pb'), PB_CATS, 'pinchbench');
      renderBars(document.getElementById('cat-bars-ko'), KO_CATS, 'clawbench_ko');

      /* ── 상세 테이블 ── */
      document.getElementById('th-a').textContent = a ? a.name : '—';
      document.getElementById('th-b').textContent = b ? b.name : '—';
      var tbody = document.getElementById('detail-body');

      function v(model, fn) { try { return model ? fn(model) : '—'; } catch(e) { return '—'; } }
      function numRow(label, va, vb, unit, reverse) {
        var na = parseFloat(va) || 0;
        var nb = parseFloat(vb) || 0;
        var ca = '', cb = '';
        if (na > 0 && nb > 0) {
          if (reverse) { ca = na < nb ? ' winner' : ''; cb = nb < na ? ' winner' : ''; }
          else { ca = na > nb ? ' winner' : ''; cb = nb > na ? ' winner' : ''; }
        }
        var su = unit || '';
        var da = va === '—' ? '—' : va + su;
        var db = vb === '—' ? '—' : vb + su;
        return '<tr><td>' + label + '</td><td class="' + ca + '">' + da + '</td><td class="' + cb + '">' + db + '</td></tr>';
      }
      function section(label) {
        return '<tr><td class="dt-section" colspan="3">' + label + '</td></tr>';
      }

      var html = '';

      /* 기본 정보 */
      html += section('기본 정보');
      html += '<tr><td>제공자</td><td>' + v(a, function(m){return m.provider_label;}) + '</td><td>' + v(b, function(m){return m.provider_label;}) + '</td></tr>';
      html += numRow('평균 속도',
        v(a, function(m){return m.avg_seconds_per_task || '—';}),
        v(b, function(m){return m.avg_seconds_per_task || '—';}), 's/task', true);

      /* PinchBench */
      html += section('PinchBench');
      html += numRow('Best',
        v(a, function(m){return m.scores.pinchbench ? m.scores.pinchbench.best.toFixed(1) : '—';}),
        v(b, function(m){return m.scores.pinchbench ? m.scores.pinchbench.best.toFixed(1) : '—';}), '%');
      html += numRow('Average',
        v(a, function(m){return m.scores.pinchbench ? m.scores.pinchbench.average.toFixed(1) : '—';}),
        v(b, function(m){return m.scores.pinchbench ? m.scores.pinchbench.average.toFixed(1) : '—';}), '%');
      html += numRow('Std',
        v(a, function(m){return m.scores.pinchbench ? '\u00b1' + m.scores.pinchbench.std.toFixed(2) : '—';}),
        v(b, function(m){return m.scores.pinchbench ? '\u00b1' + m.scores.pinchbench.std.toFixed(2) : '—';}), '');
      PB_CATS.forEach(function(c) {
        html += numRow(c.label,
          v(a, function(m){ return getCat(m,'pinchbench',c.id).toFixed(1); }),
          v(b, function(m){ return getCat(m,'pinchbench',c.id).toFixed(1); }), '%');
      });

      /* ClawBench-KO */
      html += section('ClawBench-KO');
      html += numRow('Best',
        v(a, function(m){return m.scores.clawbench_ko ? m.scores.clawbench_ko.best.toFixed(1) : '—';}),
        v(b, function(m){return m.scores.clawbench_ko ? m.scores.clawbench_ko.best.toFixed(1) : '—';}), '%');
      html += numRow('Average',
        v(a, function(m){return m.scores.clawbench_ko ? m.scores.clawbench_ko.average.toFixed(1) : '—';}),
        v(b, function(m){return m.scores.clawbench_ko ? m.scores.clawbench_ko.average.toFixed(1) : '—';}), '%');
      html += numRow('Std',
        v(a, function(m){return m.scores.clawbench_ko ? '\u00b1' + m.scores.clawbench_ko.std.toFixed(2) : '—';}),
        v(b, function(m){return m.scores.clawbench_ko ? '\u00b1' + m.scores.clawbench_ko.std.toFixed(2) : '—';}), '');
      KO_CATS.forEach(function(c) {
        html += numRow(c.label,
          v(a, function(m){ return getCat(m,'clawbench_ko',c.id).toFixed(1); }),
          v(b, function(m){ return getCat(m,'clawbench_ko',c.id).toFixed(1); }), '%');
      });

      tbody.innerHTML = html;
    }

    selA.addEventListener('change', update);
    selB.addEventListener('change', update);
    update();
  });
</script>
