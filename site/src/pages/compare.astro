---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';

let data = { meta: {}, models: [] };
try {
  const raw = readFileSync(resolve(process.cwd(), '..', 'results', 'normalized', 'leaderboard.json'), 'utf-8');
  data = JSON.parse(raw);
} catch {}

const models = data.models;
const modelsJson = JSON.stringify(models);
---

<Layout title="모델 비교">
  <div class="page-header">
    <h1>모델 <span class="accent">비교</span></h1>
    <p>두 모델의 벤치마크 결과를 나란히 비교</p>
  </div>

  <div class="compare-selectors">
    <div class="field-group">
      <label class="field-label" for="model-a">모델 A</label>
      <select id="model-a">
        <option value="">선택...</option>
        {models.map((m, i) => <option value={i} selected={i === 0}>{m.name}</option>)}
      </select>
    </div>
    <div class="compare-vs">VS</div>
    <div class="field-group">
      <label class="field-label" for="model-b">모델 B</label>
      <select id="model-b">
        <option value="">선택...</option>
        {models.map((m, i) => <option value={i} selected={i === 1}>{m.name}</option>)}
      </select>
    </div>
  </div>

  <div class="compare-grid">
    <div class="card">
      <h3>레이더 비교</h3>
      <div class="radar-wrap">
        <div id="radar-chart" style="width:100%;height:340px;"></div>
      </div>
    </div>
    <div class="card">
      <h3>지표별 비교</h3>
      <div id="metric-bars" class="metric-bars"></div>
    </div>
  </div>

  <div class="card detail-card">
    <h3>상세 정보</h3>
    <table class="detail-table" id="detail-table">
      <thead>
        <tr><th>항목</th><th id="th-a">모델 A</th><th id="th-b">모델 B</th></tr>
      </thead>
      <tbody id="detail-body"></tbody>
    </table>
  </div>
</Layout>

<style>
  .compare-selectors {
    display: flex; align-items: flex-end; gap: 20px;
    margin-bottom: 32px;
    animation: fade-up 0.5s var(--ease-out-expo) backwards;
  }
  .compare-vs {
    font-family: var(--font-display);
    font-weight: 800; font-size: 1.3rem;
    padding-bottom: 11px;
    background: linear-gradient(135deg, var(--text-3), var(--text-2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .compare-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 20px; margin-bottom: 20px;
    animation: fade-up 0.5s var(--ease-out-expo) 0.1s backwards;
  }
  .detail-card { animation: fade-up 0.5s var(--ease-out-expo) 0.2s backwards; }
  @media (max-width: 768px) {
    .compare-selectors { flex-direction: column; align-items: stretch; }
    .compare-vs { text-align: center; padding: 0; }
    .compare-grid { grid-template-columns: 1fr; }
  }
  .radar-wrap { margin-top: 8px; }
  .metric-bars { display: flex; flex-direction: column; gap: 18px; margin-top: 18px; }
  .metric-row { display: flex; flex-direction: column; gap: 5px; }
  .metric-label {
    font-size: 0.72rem; font-weight: 600; color: var(--text-3);
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  .metric-track { display: flex; height: 28px; gap: 4px; border-radius: 6px; overflow: hidden; }
  .metric-fill {
    height: 100%; border-radius: 6px; min-width: 3px;
    transition: width 0.6s var(--ease-out-expo);
    display: flex; align-items: center; justify-content: flex-end; padding-right: 8px;
    font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; color: var(--text);
  }
  .metric-fill.a { background: linear-gradient(90deg, rgba(0,232,196,0.3), rgba(0,232,196,0.15)); }
  .metric-fill.b { background: linear-gradient(90deg, rgba(167,139,250,0.3), rgba(167,139,250,0.15)); }
  .metric-fill.empty { background: rgba(10,15,30,0.4); flex: 1; }
  .detail-table { width: 100%; margin-top: 14px; }
  .detail-table th, .detail-table td { padding: 10px 14px; font-size: 0.85rem; }
  .detail-table td:first-child { color: var(--text-2); }
  .winner { color: var(--cyan); font-weight: 600; }
</style>

<script is:inline define:vars={{ modelsJson }}>
  document.addEventListener('DOMContentLoaded', function() {
    var models = JSON.parse(modelsJson);
    var selA = document.getElementById('model-a');
    var selB = document.getElementById('model-b');
    var radarChart = null;

    var METRICS = [
      { key: 'pinchbench', label: 'PinchBench', max: 100 },
      { key: 'agentbench', label: 'AgentBench', max: 100 },
      { key: 'korean',     label: '한국어',      max: 100 },
    ];

    function gs(model, key) {
      return model && model.scores && model.scores[key] ? model.scores[key].score : null;
    }

    function update() {
      var a = models[+selA.value] || null;
      var b = models[+selB.value] || null;
      var dataA = METRICS.map(function(m){ return gs(a,m.key) || 0; });
      var dataB = METRICS.map(function(m){ return gs(b,m.key) || 0; });

      /* ── ECharts Radar ── */
      var dom = document.getElementById('radar-chart');
      if (!radarChart) radarChart = echarts.init(dom);

      radarChart.setOption({
        backgroundColor: 'transparent',
        legend: {
          bottom: 0,
          textStyle: { color: '#8794b5', fontFamily: 'Noto Sans KR', fontSize: 12 },
          itemWidth: 14, itemHeight: 8,
          itemStyle: { borderWidth: 0 },
        },
        radar: {
          indicator: METRICS.map(function(m){ return { name: m.label, max: m.max }; }),
          shape: 'circle',
          splitNumber: 5,
          center: ['50%', '46%'],
          radius: '65%',
          axisName: { color: '#8794b5', fontFamily: 'Noto Sans KR', fontSize: 12 },
          axisLine: { lineStyle: { color: 'rgba(40,60,110,0.25)' } },
          splitLine: { lineStyle: { color: 'rgba(40,60,110,0.2)' } },
          splitArea: {
            areaStyle: {
              color: ['rgba(10,15,30,0.3)', 'rgba(15,22,40,0.2)', 'rgba(10,15,30,0.3)', 'rgba(15,22,40,0.2)', 'rgba(10,15,30,0.3)'],
            }
          },
        },
        series: [{
          type: 'radar',
          symbol: 'circle',
          symbolSize: 7,
          animationDuration: 800,
          animationEasing: 'cubicOut',
          data: [
            {
              name: a ? a.name : '—',
              value: dataA,
              areaStyle: { color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                { offset: 0, color: 'rgba(0,232,196,0.25)' },
                { offset: 1, color: 'rgba(0,232,196,0.02)' },
              ])},
              lineStyle: { color: '#00e8c4', width: 2.5, shadowColor: 'rgba(0,232,196,0.3)', shadowBlur: 8 },
              itemStyle: { color: '#00e8c4', borderColor: '#040712', borderWidth: 2 },
            },
            {
              name: b ? b.name : '—',
              value: dataB,
              areaStyle: { color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                { offset: 0, color: 'rgba(167,139,250,0.25)' },
                { offset: 1, color: 'rgba(167,139,250,0.02)' },
              ])},
              lineStyle: { color: '#a78bfa', width: 2.5, shadowColor: 'rgba(167,139,250,0.3)', shadowBlur: 8 },
              itemStyle: { color: '#a78bfa', borderColor: '#040712', borderWidth: 2 },
            }
          ]
        }],
        tooltip: {
          backgroundColor: 'rgba(10,15,30,0.92)',
          borderColor: 'rgba(40,60,110,0.4)', borderWidth: 1,
          textStyle: { color: '#e8ecf6', fontFamily: 'Noto Sans KR', fontSize: 13 },
        }
      }, true);

      /* ── Metric Bars ── */
      var barsEl = document.getElementById('metric-bars');
      barsEl.innerHTML = '';
      METRICS.forEach(function(m) {
        var sa = gs(a, m.key);
        var sb = gs(b, m.key);
        var pctA = sa !== null ? (sa / m.max * 50) : 0;
        var pctB = sb !== null ? (sb / m.max * 50) : 0;
        barsEl.innerHTML +=
          '<div class="metric-row">' +
            '<span class="metric-label">' + m.label + '</span>' +
            '<div class="metric-track">' +
              '<div class="metric-fill a" style="width:' + pctA + '%">' + (sa !== null ? sa.toFixed(1) : '—') + '</div>' +
              '<div class="metric-fill b" style="width:' + pctB + '%">' + (sb !== null ? sb.toFixed(1) : '—') + '</div>' +
              (pctA + pctB < 100 ? '<div class="metric-fill empty"></div>' : '') +
            '</div>' +
          '</div>';
      });

      /* ── Detail Table ── */
      document.getElementById('th-a').textContent = a ? a.name : '—';
      document.getElementById('th-b').textContent = b ? b.name : '—';
      var tbody = document.getElementById('detail-body');
      var rows = [
        ['제공자', a ? a.provider : '—', b ? b.provider : '—'],
        ['무료', a ? (a.free ? '예' : '아니오') : '—', b ? (b.free ? '예' : '아니오') : '—'],
        ['비용/회', a ? '$' + a.cost_per_run_usd.toFixed(2) : '—', b ? '$' + b.cost_per_run_usd.toFixed(2) : '—'],
        ['PinchBench 태스크', a && a.scores.pinchbench ? a.scores.pinchbench.completed + '/' + a.scores.pinchbench.total : '—', b && b.scores.pinchbench ? b.scores.pinchbench.completed + '/' + b.scores.pinchbench.total : '—'],
      ];
      tbody.innerHTML = rows.map(function(r) {
        var ca = r[1] !== '—' && r[2] !== '—' && r[1] > r[2] ? ' winner' : '';
        var cb = r[1] !== '—' && r[2] !== '—' && r[2] > r[1] ? ' winner' : '';
        return '<tr><td>' + r[0] + '</td><td class="' + ca + '">' + r[1] + '</td><td class="' + cb + '">' + r[2] + '</td></tr>';
      }).join('');
    }

    selA.addEventListener('change', update);
    selB.addEventListener('change', update);
    update();
    window.addEventListener('resize', function() { if(radarChart) radarChart.resize(); });
  });
</script>
