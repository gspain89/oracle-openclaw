---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';

let data: any = { meta: {}, models: [] };
try {
  const raw = readFileSync(resolve(process.cwd(), '..', 'results', 'normalized', 'leaderboard.json'), 'utf-8');
  data = JSON.parse(raw);
} catch {}

const models = data.models;
const modelsJson = JSON.stringify(models);
---

<Layout title="모델 비교">
  <div class="page-header">
    <h1>Model <span class="accent">Comparison</span></h1>
    <p>두 모델의 벤치마크 결과를 나란히 비교</p>
  </div>

  {models.length >= 2 ? (
    <div class="compare-selectors">
      <div class="field-group">
        <label class="field-label" for="model-a">모델 A</label>
        <select id="model-a">
          {models.map((m: any, i: number) => <option value={i} selected={i === 0}>{m.name}</option>)}
        </select>
      </div>
      <div class="compare-vs">VS</div>
      <div class="field-group">
        <label class="field-label" for="model-b">모델 B</label>
        <select id="model-b">
          {models.map((m: any, i: number) => <option value={i} selected={i === 1}>{m.name}</option>)}
        </select>
      </div>
    </div>

    <div class="compare-grid">
      <div class="card">
        <h3>레이더 비교</h3>
        <div class="radar-wrap">
          <canvas id="radar-chart" width="400" height="340"></canvas>
        </div>
      </div>
      <div class="card">
        <h3>지표별 비교</h3>
        <div id="metric-bars" class="metric-bars"></div>
      </div>
    </div>

    <div class="card detail-card">
      <h3>상세 정보</h3>
      <table class="detail-table" id="detail-table">
        <thead>
          <tr><th>항목</th><th id="th-a">모델 A</th><th id="th-b">모델 B</th></tr>
        </thead>
        <tbody id="detail-body"></tbody>
      </table>
    </div>
  ) : (
    <div class="card">
      <div class="empty-state">
        <div class="icon">VS</div>
        <h3>비교할 모델이 없습니다</h3>
        <p>벤치마크 결과가 2개 이상 수집되면 모델 비교가 가능합니다.</p>
      </div>
    </div>
  )}
</Layout>

<style is:global>
  .compare-selectors {
    display: flex; align-items: flex-end; gap: 20px;
    margin-bottom: 32px;
    animation: fade-up 0.5s var(--ease-out-expo) backwards;
  }
  .compare-vs {
    font-family: var(--font-display);
    font-size: 1.3rem;
    padding-bottom: 11px;
    color: var(--text-3);
  }
  .compare-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 20px; margin-bottom: 20px;
    animation: fade-up 0.5s var(--ease-out-expo) 0.1s backwards;
  }
  .detail-card { animation: fade-up 0.5s var(--ease-out-expo) 0.2s backwards; }
  @media (max-width: 768px) {
    .compare-selectors { flex-direction: column; align-items: stretch; }
    .compare-vs { text-align: center; padding: 0; }
    .compare-grid { grid-template-columns: 1fr; }
  }
  .radar-wrap { margin-top: 8px; display: flex; justify-content: center; }
  .metric-bars { display: flex; flex-direction: column; gap: 18px; margin-top: 18px; }
  .metric-row { display: flex; flex-direction: column; gap: 5px; }
  .metric-label {
    font-size: 0.72rem; font-weight: 600; color: var(--text-3);
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  .metric-track { display: flex; height: 28px; gap: 4px; border-radius: 6px; overflow: hidden; }
  .metric-fill {
    height: 100%; border-radius: 6px; min-width: 3px;
    display: flex; align-items: center; justify-content: flex-end; padding-right: 8px;
    font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; color: var(--text-inv);
  }
  .metric-fill.a { background: var(--bar-best); }
  .metric-fill.b { background: var(--blue); }
  .metric-fill.empty { background: var(--bg-track); flex: 1; }
  .detail-table { width: 100%; margin-top: 14px; }
  .detail-table th, .detail-table td { padding: 10px 14px; font-size: 0.85rem; }
  .detail-table td:first-child { color: var(--text-2); }
  .winner { color: var(--accent); font-weight: 600; }
</style>

<script is:inline define:vars={{ modelsJson }}>
  document.addEventListener('DOMContentLoaded', function() {
    var models = JSON.parse(modelsJson);
    var selA = document.getElementById('model-a');
    var selB = document.getElementById('model-b');
    var radarChart = null;

    var METRICS = [
      { key: 'pinchbench', label: 'PinchBench', max: 100, get: function(m) { return m.scores.pinchbench ? m.scores.pinchbench.best : 0; } },
      { key: 'clawbench_ko', label: 'ClawBench-KO', max: 100, get: function(m) { return m.scores.clawbench_ko ? m.scores.clawbench_ko.best : 0; } },
      { key: 'speed', label: '속도 (norm)', max: 100, get: function(m) {
        var maxT = 55, minT = 15;
        var t = m.avg_seconds_per_task || maxT;
        return Math.max(0, Math.min(100, 100 - ((t - minT) / (maxT - minT)) * 100));
      }},
      { key: 'cost', label: '가성비 (norm)', max: 100, get: function(m) {
        if (m.cost_per_run_usd === 0) return 100;
        return Math.max(0, 100 - (m.cost_per_run_usd / 1.0) * 100);
      }},
    ];

    function update() {
      var a = models[+selA.value] || null;
      var b = models[+selB.value] || null;
      var dataA = METRICS.map(function(m) { return a ? m.get(a) : 0; });
      var dataB = METRICS.map(function(m) { return b ? m.get(b) : 0; });

      /* Chart.js Radar */
      var ctx = document.getElementById('radar-chart');
      if (radarChart) radarChart.destroy();

      radarChart = new Chart(ctx, {
        type: 'radar',
        data: {
          labels: METRICS.map(function(m) { return m.label; }),
          datasets: [
            {
              label: a ? a.name : '—',
              data: dataA,
              backgroundColor: 'rgba(140, 36, 22, 0.1)',
              borderColor: '#8c2416',
              borderWidth: 2.5,
              pointBackgroundColor: '#8c2416',
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
              pointRadius: 5,
            },
            {
              label: b ? b.name : '—',
              data: dataB,
              backgroundColor: 'rgba(37, 99, 168, 0.1)',
              borderColor: '#2563a8',
              borderWidth: 2.5,
              pointBackgroundColor: '#2563a8',
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
              pointRadius: 5,
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          scales: {
            r: {
              beginAtZero: true,
              max: 100,
              ticks: {
                stepSize: 20,
                color: '#9e9082',
                font: { family: 'IBM Plex Mono', size: 10 },
                backdropColor: 'transparent',
              },
              grid: { color: 'rgba(120, 100, 70, 0.12)' },
              angleLines: { color: 'rgba(120, 100, 70, 0.12)' },
              pointLabels: {
                color: '#6b5e50',
                font: { family: 'Noto Sans KR', size: 12, weight: '500' },
              },
            }
          },
          plugins: {
            legend: {
              labels: {
                color: '#6b5e50',
                font: { family: 'Noto Sans KR', size: 12 },
                usePointStyle: true,
                pointStyle: 'circle',
              }
            },
            tooltip: {
              backgroundColor: 'rgba(26, 20, 16, 0.92)',
              titleColor: '#f0ead8',
              bodyColor: '#f0ead8',
              borderColor: 'rgba(120, 100, 70, 0.3)',
              borderWidth: 1,
              bodyFont: { family: 'IBM Plex Mono' },
            }
          },
          animation: { duration: 600, easing: 'easeOutCubic' },
        }
      });

      /* Metric Bars */
      var barsEl = document.getElementById('metric-bars');
      barsEl.innerHTML = '';
      METRICS.forEach(function(m) {
        var sa = a ? m.get(a) : 0;
        var sb = b ? m.get(b) : 0;
        var pctA = sa / m.max * 45;
        var pctB = sb / m.max * 45;
        barsEl.innerHTML +=
          '<div class="metric-row">' +
            '<span class="metric-label">' + m.label + '</span>' +
            '<div class="metric-track">' +
              '<div class="metric-fill a" style="width:' + pctA + '%">' + sa.toFixed(1) + '</div>' +
              '<div class="metric-fill b" style="width:' + pctB + '%">' + sb.toFixed(1) + '</div>' +
              '<div class="metric-fill empty"></div>' +
            '</div>' +
          '</div>';
      });

      /* Detail Table */
      document.getElementById('th-a').textContent = a ? a.name : '—';
      document.getElementById('th-b').textContent = b ? b.name : '—';
      var tbody = document.getElementById('detail-body');

      function val(model, fn, fallback) { return model ? fn(model) : fallback || '—'; }

      var rows = [
        ['제공자', val(a, function(m){return m.provider_label;}), val(b, function(m){return m.provider_label;})],
        ['무료', val(a, function(m){return m.free ? '예' : '아니오';}), val(b, function(m){return m.free ? '예' : '아니오';})],
        ['비용/회', val(a, function(m){return '$' + m.cost_per_run_usd.toFixed(2);}), val(b, function(m){return '$' + m.cost_per_run_usd.toFixed(2);})],
        ['파라미터', val(a, function(m){return m.params_b + 'B';}), val(b, function(m){return m.params_b + 'B';})],
        ['평균 속도', val(a, function(m){return m.avg_seconds_per_task + 's/task';}), val(b, function(m){return m.avg_seconds_per_task + 's/task';})],
        ['PinchBench (best)', val(a, function(m){return m.scores.pinchbench ? m.scores.pinchbench.best.toFixed(1) : '—';}), val(b, function(m){return m.scores.pinchbench ? m.scores.pinchbench.best.toFixed(1) : '—';})],
        ['ClawBench-KO (best)', val(a, function(m){return m.scores.clawbench_ko ? m.scores.clawbench_ko.best.toFixed(1) : '—';}), val(b, function(m){return m.scores.clawbench_ko ? m.scores.clawbench_ko.best.toFixed(1) : '—';})],
      ];

      tbody.innerHTML = rows.map(function(r) {
        var va = parseFloat(r[1]) || 0;
        var vb = parseFloat(r[2]) || 0;
        var ca = va > vb && va > 0 ? ' winner' : '';
        var cb = vb > va && vb > 0 ? ' winner' : '';
        return '<tr><td>' + r[0] + '</td><td class="' + ca + '">' + r[1] + '</td><td class="' + cb + '">' + r[2] + '</td></tr>';
      }).join('');
    }

    selA.addEventListener('change', update);
    selB.addEventListener('change', update);
    update();
  });
</script>
