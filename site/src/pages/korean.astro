---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';

let data: any = { meta: {}, models: [] };
try {
  const raw = readFileSync(resolve(process.cwd(), '..', 'results', 'normalized', 'leaderboard.json'), 'utf-8');
  data = JSON.parse(raw);
} catch {}

const models = data.models;
const hasKorean = models.some((m: any) => m.scores?.clawbench_ko);

const ranked = [...models]
  .filter((m: any) => m.scores?.clawbench_ko)
  .sort((a: any, b: any) => b.scores.clawbench_ko.best - a.scores.clawbench_ko.best);

const categories = [
  { id: 'data_processing', name: '데이터 처리', count: 4, desc: 'CSV 변환, JSON 분석, 로그 파싱, 데이터 병합' },
  { id: 'document_generation', name: '문서 생성', count: 3, desc: '인보이스 생성, 보고서 작성, 이메일 초안' },
  { id: 'korean_system', name: '한국 시스템', count: 3, desc: '주소 파싱, 금액 변환, 전화번호 정규화' },
];

const chartData = JSON.stringify(ranked.map((m: any) => ({
  name: m.name,
  categories: m.scores.clawbench_ko.categories,
})));
---

<Layout title="ClawBench-KO">
  <div class="page-header">
    <h1>ClawBench-<span class="accent">KO</span></h1>
    <p>한국어 처리 / 문서 생성 / 한국 시스템 &mdash; 10개 태스크 커스텀 벤치마크</p>
  </div>

  {hasKorean ? (
    <section class="chart-card card">
      <h3>모델별 종합 점수 (Best / Average)</h3>
      <div class="bar-legend">
        <span class="legend-item"><span class="legend-dot best"></span> Best</span>
        <span class="legend-item"><span class="legend-dot avg"></span> Average</span>
      </div>
      <div class="bar-chart">
        {ranked.map((m: any, i: number) => {
          const ko = m.scores.clawbench_ko;
          const runsCount = ko.runs?.length || 1;
          const stdVal = ko.std != null ? `\u00b1${ko.std.toFixed(2)}` : '';
          return (
            <div class="bar-row" style={`--delay: ${i * 0.06}s`}>
              <div class="bar-rank">
                <span class={`rank-badge ${i < 3 ? `top-${i+1}` : ''}`}>{i+1}</span>
              </div>
              <div class="bar-info">
                <span class="bar-model-name">{m.name}</span>
                <span class="bar-provider">{m.provider_label}</span>
              </div>
              <div class="bar-tracks">
                <div class="bar-track">
                  <div class="bar-fill best" style={`width:${ko.best}%`}>
                    <span class="bar-value">{ko.best.toFixed(1)}</span>
                  </div>
                </div>
                <div class="bar-track">
                  <div class="bar-fill avg" style={`width:${ko.average}%`}>
                    <span class="bar-value">{ko.average.toFixed(1)}</span>
                  </div>
                </div>
              </div>
              <div class="bar-tooltip">
                <div class="tooltip-header">{m.name}</div>
                <div class="tooltip-sub">{m.provider_label}</div>
                <div class="tooltip-row"><span class="tooltip-label">Best score</span><span class="tooltip-val">{ko.best.toFixed(1)}%</span></div>
                <div class="tooltip-row"><span class="tooltip-label">Avg score</span><span class="tooltip-val">{ko.average.toFixed(1)}%</span></div>
                {stdVal && <div class="tooltip-row"><span class="tooltip-label">Std</span><span class="tooltip-val">{stdVal}</span></div>}
                <div class="tooltip-row"><span class="tooltip-label">Runs</span><span class="tooltip-val">{runsCount}</span></div>
                {ko.runs && ko.runs.length > 0 && (
                  <Fragment>
                    <hr class="tooltip-divider" />
                    <div class="tooltip-runs-title">개별 실행</div>
                    {ko.runs.map((run: any, ri: number) => (
                      <div class="tooltip-run-item">
                        <span class="tooltip-run-date">{run.date || `Run ${ri+1}`}</span>
                        <span class="tooltip-run-score">{run.score.toFixed(1)}%</span>
                      </div>
                    ))}
                  </Fragment>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  ) : (
    <div class="card">
      <div class="empty-state">
        <div class="icon">KO</div>
        <h3>ClawBench-KO 결과 준비 중</h3>
        <p>ClawBench-KO 결과가 수집되면 여기에 표시됩니다.</p>
      </div>
    </div>
  )}

  {hasKorean && (
    <section class="chart-card card" style="margin-top:24px;">
      <h3>카테고리별 비교</h3>
      <div class="chart-wrap">
        <canvas id="category-chart" height="70"></canvas>
      </div>
    </section>
  )}

  <div class="categories">
    {categories.map(cat => (
      <div class="cat-card card">
        <div class="cat-header">
          <h3>{cat.name}</h3>
          <span class="cat-count">{cat.count}개 태스크</span>
        </div>
        <p class="cat-desc">{cat.desc}</p>
        {hasKorean && (
          <div class="cat-scores">
            {ranked.slice(0, 3).map((m: any, i: number) => (
              <div class="cat-score-row">
                <span class="cat-score-rank">{i+1}.</span>
                <span class="cat-score-name">{m.name}</span>
                <span class="cat-score-val">{(m.scores.clawbench_ko.categories[cat.id] || 0).toFixed(1)}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>

  <div class="card scoring-info" style="margin-top:24px;">
    <h3>채점 방식</h3>
    <div class="scoring-grid">
      <div class="scoring-item">
        <div class="scoring-type">Structured</div>
        <p>JSON 필드 정확도 비교 (주소, 번호, 금액 등 구조화된 출력)</p>
      </div>
      <div class="scoring-item">
        <div class="scoring-type">Semantic</div>
        <p>LLM 기반 판정 &mdash; GPT-5.3이 의미적 정확성 평가</p>
      </div>
      <div class="scoring-item">
        <div class="scoring-type">Exact</div>
        <p>정확 일치 &mdash; 변환, 정규화 태스크에서 기대값과 1:1 비교</p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .chart-card { animation: fade-up 0.5s var(--ease-out-expo) backwards; }
  .chart-wrap { margin-top: 16px; }
  .categories {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-top: 24px;
    animation: fade-up 0.5s var(--ease-out-expo) 0.1s backwards;
  }
  .cat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
  }
  .cat-count {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-3);
    padding: 2px 8px;
    background: var(--bg-warm);
    border-radius: var(--radius-sm);
  }
  .cat-desc {
    font-size: 0.82rem; color: var(--text-2); line-height: 1.5;
    margin-bottom: 12px;
  }
  .cat-scores { display: flex; flex-direction: column; gap: 4px; }
  .cat-score-row {
    display: grid;
    grid-template-columns: 20px 1fr auto;
    gap: 6px;
    align-items: center;
    padding: 4px 8px;
    background: var(--bg-card-alt);
    border-radius: 4px;
    font-size: 0.8rem;
  }
  .cat-score-rank { font-family: var(--font-mono); color: var(--text-3); font-size: 0.72rem; }
  .cat-score-name { color: var(--text-2); }
  .cat-score-val { font-family: var(--font-mono); font-weight: 600; color: var(--accent); }
  .scoring-info { animation: fade-up 0.5s var(--ease-out-expo) 0.2s backwards; }
  .scoring-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px;
    margin-top: 14px;
  }
  .scoring-item {
    padding: 14px;
    background: var(--bg-card-alt);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }
  .scoring-type {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.78rem;
    color: var(--accent);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .scoring-item p { font-size: 0.82rem; color: var(--text-2); line-height: 1.5; }
</style>

<script is:inline define:vars={{ chartData }}>
  document.addEventListener('DOMContentLoaded', function() {
    var models = JSON.parse(chartData);
    var ctx = document.getElementById('category-chart');
    if (!ctx || !models.length) return;

    // 카테고리별 색상 — 각 카테고리가 고유 색상을 가짐
    var cats = ['data_processing', 'document_generation', 'korean_system'];
    var catLabels = ['데이터 처리', '문서 생성', '한국 시스템'];
    var catColors = ['#8c5e3c', '#2d7a3e', '#2563a8'];

    // X축 = 모델명, 각 그룹 내 3개 바 = 카테고리별 색상
    var labels = models.map(function(m) { return m.name; });
    var datasets = cats.map(function(cat, ci) {
      return {
        label: catLabels[ci],
        data: models.map(function(m) { return m.categories[cat] || 0; }),
        backgroundColor: catColors[ci] + 'aa',
        borderColor: catColors[ci],
        borderWidth: 1.5,
        borderRadius: 4,
        maxBarThickness: 48,
      };
    });

    new Chart(ctx, {
      type: 'bar',
      data: { labels: labels, datasets: datasets },
      options: {
        responsive: true,
        scales: {
          x: {
            ticks: { color: '#6b5e50', font: { family: 'Noto Sans KR', size: 12 } },
            grid: { display: false },
            border: { color: 'rgba(120,100,70,0.15)' },
          },
          y: {
            min: 0, max: 100,
            ticks: {
              color: '#9e9082',
              font: { family: 'IBM Plex Mono', size: 11 },
              callback: function(v) { return v + '%'; },
            },
            grid: { color: 'rgba(120,100,70,0.08)' },
            border: { color: 'rgba(120,100,70,0.15)' },
          }
        },
        plugins: {
          legend: {
            labels: {
              color: '#6b5e50',
              font: { family: 'Noto Sans KR', size: 11 },
              usePointStyle: true,
              pointStyle: 'rect',
            }
          },
          tooltip: {
            backgroundColor: 'rgba(26,20,16,0.92)',
            titleColor: '#f0ead8',
            bodyColor: '#f0ead8',
            borderColor: 'rgba(120,100,70,0.3)',
            borderWidth: 1,
            bodyFont: { family: 'IBM Plex Mono' },
            callbacks: {
              label: function(c) { return c.dataset.label + ': ' + c.parsed.y.toFixed(1) + '%'; }
            }
          }
        },
        animation: { duration: 700, easing: 'easeOutCubic' },
      },
      plugins: [{
        afterDatasetsDraw: function(chart) {
          var c = chart.ctx;
          chart.data.datasets.forEach(function(ds, i) {
            var meta = chart.getDatasetMeta(i);
            meta.data.forEach(function(bar, idx) {
              var val = ds.data[idx];
              if (val > 0) {
                c.fillStyle = '#4a3f35';
                c.textAlign = 'center';
                c.font = '600 11px IBM Plex Mono';
                c.fillText(val.toFixed(1), bar.x, bar.y - 6);
              }
            });
          });
        }
      }]
    });
  });
</script>
