---
import Layout from '../layouts/Layout.astro';
import { readFileSync, readdirSync } from 'fs';
import { resolve } from 'path';

let runsData: any = { meta: { total: 0, included: 0, excluded: 0 }, runs: [] };
try {
  const raw = readFileSync(resolve(process.cwd(), '..', 'results', 'normalized', 'runs.json'), 'utf-8');
  runsData = JSON.parse(raw);
} catch {}

const detailsMap: Record<string, any> = {};
try {
  const detailsDir = resolve(process.cwd(), '..', 'results', 'normalized', 'run-details');
  for (const f of readdirSync(detailsDir).filter((x: string) => x.endsWith('.json'))) {
    detailsMap['run-details/' + f] = JSON.parse(readFileSync(resolve(detailsDir, f), 'utf-8'));
  }
} catch {}

const { meta, runs } = runsData;
const benchLabels: Record<string, string> = {
  pinchbench: 'PinchBench',
  clawbench_ko: 'ClawBench-KO',
};
const detailsJson = JSON.stringify(detailsMap);
---

<Layout title="실행 기록">
  <div class="page-header">
    <h1>Run <span class="accent">History</span></h1>
    <p>개별 벤치마크 실행 기록 &mdash; normalize 포함 여부 및 삭제 경로</p>
  </div>

  <div class="stats-row">
    <div class="stat-card">
      <span class="stat-value">{meta.total}</span>
      <span class="stat-label">전체 Run</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">{meta.included}</span>
      <span class="stat-label">리더보드 포함</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">{meta.excluded}</span>
      <span class="stat-label">제외</span>
    </div>
  </div>

  {runs.length > 0 ? (
    <section class="table-section">
      <div class="table-controls">
        <div class="filter-bar">
          <button class="filter-btn active" data-filter="all">전체</button>
          <button class="filter-btn" data-filter="included">포함</button>
          <button class="filter-btn" data-filter="excluded">제외</button>
        </div>
      </div>
      <div class="table-wrap">
        <table id="runs-table">
          <thead>
            <tr>
              <th class="col-status">상태</th>
              <th>모델</th>
              <th>벤치마크</th>
              <th class="col-score">점수</th>
              <th class="col-tasks">태스크</th>
              <th>날짜</th>
              <th class="col-path">삭제 경로</th>
            </tr>
          </thead>
          <tbody>
            {runs.map((r: any) => (
              <tr class={`run-row ${r.included ? 'included' : 'excluded'}${r.detail_file ? ' has-detail' : ''}`} data-included={r.included ? 'yes' : 'no'} data-detail={r.detail_file || ''}>
                <td class="col-status">
                  {r.included
                    ? <span class="status-badge status-included" title="리더보드에 포함됨">포함</span>
                    : <span class="status-badge status-excluded" title={r.skip_reason || '제외됨'}>제외</span>}
                </td>
                <td>
                  <span class="model-name">{r.model_id || '(unknown)'}</span>
                </td>
                <td>
                  <span class="bench-tag">{benchLabels[r.benchmark] || r.benchmark}</span>
                </td>
                <td class="col-score score-mono">
                  {r.score != null
                    ? <span class={r.score >= 70 ? 'score-high' : r.score >= 40 ? 'score-mid' : 'score-low'}>{r.score.toFixed(1)}%</span>
                    : <span class="no-data">&mdash;</span>}
                </td>
                <td class="col-tasks score-mono">
                  {r.completed != null ? `${r.completed}/${r.total}` : <span class="no-data">&mdash;</span>}
                </td>
                <td class="date-cell">{r.date || <span class="no-data">&mdash;</span>}</td>
                <td class="col-path">
                  <code class="rm-path" title={`rm -rf ${r.rm_path}`}>{r.rm_path}</code>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  ) : (
    <div class="card">
      <div class="empty-state">
        <div class="icon">RUN</div>
        <h3>실행 기록 없음</h3>
        <p>normalize.py 실행 후 runs.json이 생성되면 여기에 표시됩니다.</p>
      </div>
    </div>
  )}

  <div class="card help-card">
    <h3>삭제 방법</h3>
    <p>서버에서 해당 run을 삭제하고 리더보드에서 제외하려면:</p>
    <pre><code set:html={`# 1) 결과 파일/디렉토리 삭제\nrm -rf <삭제 경로>\n\n# 2) normalize 재실행\npython3 server/python/normalize.py\n\n# 3) 배포\nbash server/scripts/deploy-results.sh`} /></pre>
  </div>

  <div id="panel-backdrop" class="panel-backdrop"></div>
  <aside id="detail-panel" class="slide-panel">
    <div class="panel-header">
      <div class="panel-title-row">
        <h2 id="panel-title"></h2>
        <button id="panel-close" class="panel-close">&times;</button>
      </div>
      <div class="panel-meta" id="panel-meta"></div>
    </div>
    <div class="panel-body" id="panel-body"></div>
  </aside>
</Layout>

<style>
  .table-section {
    animation: fade-up 0.5s var(--ease-out-expo) 0.2s backwards;
  }
  .table-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  .filter-bar {
    display: flex;
    gap: 4px;
    padding: 4px;
    background: var(--bg-warm);
    border-radius: var(--radius-sm);
  }
  .filter-btn {
    padding: 6px 16px;
    border: none;
    border-radius: calc(var(--radius-sm) - 2px);
    background: transparent;
    color: var(--text-2);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }
  .filter-btn:hover { color: var(--text); }
  .filter-btn.active {
    background: var(--bg-card);
    color: var(--accent);
    font-weight: 700;
    box-shadow: var(--shadow-sm);
  }

  .col-status { width: 64px; text-align: center; }
  td.col-status { text-align: center; }
  .col-score { min-width: 72px; }
  .col-tasks { min-width: 64px; }
  .col-path { min-width: 200px; }

  .status-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.03em;
  }
  .status-included {
    background: rgba(45, 122, 62, 0.1);
    color: var(--green);
    border: 1px solid rgba(45, 122, 62, 0.2);
  }
  .status-excluded {
    background: rgba(201, 42, 42, 0.08);
    color: var(--red);
    border: 1px solid rgba(201, 42, 42, 0.15);
  }

  .bench-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-2);
    padding: 2px 8px;
    background: var(--bg-warm);
    border-radius: 4px;
  }

  .score-high { color: var(--green); font-weight: 600; }
  .score-mid { color: var(--gold); font-weight: 600; }
  .score-low { color: var(--red); font-weight: 600; }

  .date-cell {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-2);
  }

  .rm-path {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-2);
    background: var(--bg-card-alt);
    padding: 2px 6px;
    border-radius: 3px;
    border: 1px solid var(--border);
    cursor: pointer;
    word-break: break-all;
    transition: background 0.15s, color 0.15s;
  }
  .rm-path:hover {
    background: rgba(201, 42, 42, 0.08);
    color: var(--red);
  }

  tr.excluded { opacity: 0.6; }
  tr.excluded:hover { opacity: 1; }
  tr.run-row.hidden { display: none; }

  .help-card {
    margin-top: 24px;
    animation: fade-up 0.5s var(--ease-out-expo) 0.3s backwards;
  }
  .help-card p {
    font-size: 0.85rem;
    color: var(--text-2);
    margin: 8px 0 12px;
  }
  .help-card pre {
    background: var(--bg-card-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 14px 18px;
    overflow-x: auto;
  }
  .help-card code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text);
    line-height: 1.7;
  }

  tr.has-detail { cursor: pointer; }
  tr.has-detail:hover { background: var(--bg-warm); }

  /* ── 슬라이딩 패널 ── */
  .panel-backdrop {
    position: fixed; top: 61px; left: 0; right: 0; bottom: 0;
    z-index: 999;
    background: rgba(26,20,16,0.35);
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s;
  }
  .panel-backdrop.open { opacity: 1; pointer-events: auto; }

  .slide-panel {
    position: fixed; top: 61px; right: 0; bottom: 0;
    width: min(480px, 92vw);
    background: var(--bg-page);
    border-left: 1px solid var(--border);
    box-shadow: -8px 0 32px rgba(0,0,0,0.1);
    z-index: 1000;
    display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
  }
  .slide-panel.open { transform: translateX(0); }

  .panel-header {
    padding: 16px 18px 12px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .panel-title-row {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 8px;
  }
  .panel-title-row h2 {
    font-size: 0.92rem; font-weight: 700; margin: 0;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .panel-close {
    background: none; border: none; font-size: 1.3rem;
    color: var(--text-3); cursor: pointer; padding: 2px 6px;
    line-height: 1; border-radius: 4px; transition: all 0.15s;
  }
  .panel-close:hover { background: var(--bg-warm); color: var(--text); }
  .panel-meta { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }

  .panel-body {
    flex: 1; overflow-y: auto; padding: 12px 16px 20px;
    overscroll-behavior: contain;
  }

  @media (max-width: 600px) {
    .slide-panel { width: 100vw; }
  }
</style>

<style is:global>
  /* 패널 내부 — JS innerHTML로 삽입되므로 global 필요 */

  .slide-panel .panel-summary {
    display: flex; gap: 8px; align-items: center;
    padding: 8px 10px; margin-bottom: 10px;
    background: var(--bg-card-alt); border-radius: var(--radius-sm);
    font-size: 0.7rem; color: var(--text-2);
  }

  .slide-panel .p-tag {
    display: inline-block;
    font-family: var(--font-mono); font-size: 0.58rem; font-weight: 600;
    padding: 1px 6px; border-radius: 3px;
    letter-spacing: 0.02em; vertical-align: middle;
  }
  .slide-panel .p-tag-bench { background: rgba(37,99,168,0.1); color: #2563a8; }
  .slide-panel .p-tag-date  { background: var(--bg-warm); color: var(--text-3); }
  .slide-panel .p-tag-score { font-size: 0.62rem; font-weight: 700; }
  .slide-panel .p-tag-score.pass    { background: rgba(45,122,62,0.12); color: var(--green); }
  .slide-panel .p-tag-score.partial { background: rgba(196,132,45,0.12); color: var(--gold); }
  .slide-panel .p-tag-score.fail    { background: rgba(201,42,42,0.1); color: var(--red); }
  .slide-panel .p-tag-type { background: var(--bg-warm); color: var(--text-3); }
  .slide-panel .p-tag-cat  { background: rgba(124,58,237,0.08); color: #7c3aed; }
  .slide-panel .p-tag-timeout { background: rgba(201,42,42,0.1); color: var(--red); }

  .slide-panel .tc {
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    margin-bottom: 5px; overflow: hidden;
    background: var(--bg-card);
  }
  .slide-panel .tc-head {
    display: grid; grid-template-columns: 18px 6px 1fr auto; gap: 6px;
    align-items: center;
    padding: 6px 10px; cursor: pointer; user-select: none;
    transition: background 0.12s;
  }
  .slide-panel .tc-num {
    font-family: var(--font-mono); font-size: 0.6rem; font-weight: 600;
    color: var(--text-3); text-align: right;
  }
  .slide-panel .tc-head:hover { background: var(--bg-card-alt); }
  .slide-panel .tc-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  .slide-panel .tc-dot.pass    { background: var(--green); }
  .slide-panel .tc-dot.partial { background: var(--gold); }
  .slide-panel .tc-dot.fail    { background: var(--red); }
  .slide-panel .tc-info { min-width: 0; }
  .slide-panel .tc-name {
    font-size: 0.72rem; font-weight: 600; color: var(--text);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    display: block;
  }
  .slide-panel .tc-tags { display: flex; gap: 3px; margin-top: 2px; flex-wrap: wrap; }
  .slide-panel .tc-score {
    font-family: var(--font-mono); font-size: 0.66rem; font-weight: 700;
    flex-shrink: 0;
  }
  .slide-panel .tc-score.pass    { color: var(--green); }
  .slide-panel .tc-score.partial { color: var(--gold); }
  .slide-panel .tc-score.fail    { color: var(--red); }

  .slide-panel .tc-body {
    display: none; padding: 8px 10px 10px;
    border-top: 1px solid var(--border);
    background: var(--bg-card-alt);
  }
  .slide-panel .tc.open .tc-body { display: block; }

  .slide-panel .ds { margin-bottom: 7px; }
  .slide-panel .ds:last-child { margin-bottom: 0; }
  .slide-panel .ds-label {
    font-family: var(--font-mono); font-size: 0.56rem; font-weight: 700;
    color: var(--accent); text-transform: uppercase; letter-spacing: 0.06em;
    margin-bottom: 3px;
  }
  .slide-panel .ds-text {
    font-size: 0.68rem; color: var(--text-2); line-height: 1.5;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 4px; padding: 5px 8px;
    max-height: 110px; overflow-y: auto;
    white-space: pre-wrap; word-break: break-word;
  }

  .slide-panel .ck-list { list-style: none; padding: 0; margin: 0; }
  .slide-panel .ck-item {
    display: flex; align-items: baseline; gap: 4px;
    padding: 1px 0; font-size: 0.66rem; color: var(--text-2);
  }
  .slide-panel .ck-icon { flex-shrink: 0; font-size: 0.7rem; }
  .slide-panel .ck-icon.pass { color: var(--green); }
  .slide-panel .ck-icon.fail { color: var(--red); }

  .slide-panel .bd-grid {
    display: grid; grid-template-columns: 1fr auto;
    gap: 1px 10px; font-size: 0.66rem;
    padding: 4px 8px;
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 4px;
  }
  .slide-panel .bd-key { color: var(--text-2); }
  .slide-panel .bd-val { font-family: var(--font-mono); font-weight: 600; color: var(--text); text-align: right; }
</style>

<script is:inline define:vars={{ detailsJson }}>
  document.addEventListener('DOMContentLoaded', function() {
    var allDetails = JSON.parse(detailsJson);
    var filterBtns = document.querySelectorAll('.filter-btn');
    var rows = document.querySelectorAll('.run-row');

    filterBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        filterBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        var f = btn.dataset.filter;
        rows.forEach(function(r) {
          if (f === 'all') r.classList.remove('hidden');
          else if (f === 'included') r.classList.toggle('hidden', r.dataset.included !== 'yes');
          else r.classList.toggle('hidden', r.dataset.included === 'yes');
        });
      });
    });

    document.querySelectorAll('.rm-path').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.stopPropagation();
        navigator.clipboard.writeText('rm -rf ' + el.textContent).then(function() {
          var o = el.textContent;
          el.textContent = 'copied!'; el.style.color = 'var(--green)';
          setTimeout(function() { el.textContent = o; el.style.color = ''; }, 1200);
        });
      });
    });

    var panel = document.getElementById('detail-panel');
    var backdrop = document.getElementById('panel-backdrop');
    var pTitle = document.getElementById('panel-title');
    var pMeta = document.getElementById('panel-meta');
    var pBody = document.getElementById('panel-body');

    function sc(s) { return s >= 80 ? 'pass' : s >= 40 ? 'partial' : 'fail'; }
    function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
    function tag(cls, txt) { return '<span class="p-tag ' + cls + '">' + esc(txt) + '</span>'; }

    function checkText(c) {
      var ck = c.check;
      if (typeof ck === 'string') return ck;
      if (ck && typeof ck === 'object') {
        var t = ck.type || '';
        if (ck.path) t += ': ' + ck.path;
        if (ck.field) t += ' \u2192 ' + ck.field;
        if (ck.expected != null) t += ' = ' + ck.expected;
        if (ck.fields) t += ' [' + ck.fields.join(', ') + ']';
        return t;
      }
      return c.name || c.description || '';
    }
    function renderChecks(checks) {
      if (!checks || !checks.length) return '';
      return '<ul class="ck-list">' + checks.map(function(c) {
        var ok = c.passed || c.pass;
        return '<li class="ck-item"><span class="ck-icon ' + (ok?'pass':'fail') + '">' +
          (ok?'\u2713':'\u2717') + '</span><span>' + esc(checkText(c)) + '</span></li>';
      }).join('') + '</ul>';
    }

    function renderBd(bd) {
      if (!bd || typeof bd !== 'object') return '';
      var keys = Object.keys(bd);
      if (!keys.length) return '';
      return '<div class="bd-grid">' + keys.map(function(k) {
        var v = bd[k];
        return '<span class="bd-key">' + esc(k) + '</span><span class="bd-val">' +
          esc(typeof v === 'number' ? v.toFixed(1) : String(v)) + '</span>';
      }).join('') + '</div>';
    }

    function renderTask(t, i, total) {
      var cls = sc(t.score);
      var num = (i + 1) + '/' + total;
      var h = '<div class="tc" id="tc-' + i + '">';
      h += '<div class="tc-head" data-i="' + i + '">';
      h += '<span class="tc-num">' + (i + 1) + '</span>';
      h += '<span class="tc-dot ' + cls + '"></span>';
      h += '<div class="tc-info"><span class="tc-name">' + esc(t.name||t.task_id) + '</span>';
      h += '<div class="tc-tags">';
      if (t.grading_type) h += tag('p-tag-type', t.grading_type);
      if (t.group) h += tag('p-tag-cat', t.group);
      else if (t.category) h += tag('p-tag-cat', t.category);
      if (t.execution_time > 0) h += tag('p-tag-date', t.execution_time.toFixed(0) + 's');
      if (t.timed_out) h += tag('p-tag-timeout', 'TIMEOUT');
      h += '</div></div>';
      h += '<span class="tc-score ' + cls + '">' + t.score.toFixed(1) + '</span>';
      h += '</div>';

      h += '<div class="tc-body">';
      if (t.prompt) {
        h += '<div class="ds"><div class="ds-label">Prompt</div>';
        h += '<div class="ds-text">' + esc(t.prompt) + '</div></div>';
      }
      var checks = t.checks || (t.automated && t.automated.details) || null;
      if (checks && checks.length) {
        h += '<div class="ds"><div class="ds-label">Automated Checks</div>';
        h += renderChecks(checks);
        if (t.automated && t.automated.score != null)
          h += '<div style="margin-top:2px;font-size:0.62rem;color:var(--text-3)">score: ' + (t.automated.score*100).toFixed(1) + '%</div>';
        h += '</div>';
      }
      var bd = t.breakdown || (t.judge && t.judge.breakdown) || null;
      if (bd) {
        h += '<div class="ds"><div class="ds-label">Judge Breakdown</div>' + renderBd(bd);
        if (t.judge && t.judge.score != null)
          h += '<div style="margin-top:2px;font-size:0.62rem;color:var(--text-3)">score: ' + (t.judge.score*100).toFixed(1) + '%</div>';
        h += '</div>';
      }
      if (t.weights && (t.weights.automated != null || t.weights.judge != null)) {
        h += '<div class="ds"><div class="ds-label">Weights</div>';
        h += '<div style="font-size:0.65rem;color:var(--text-2)">auto ' + ((t.weights.automated||0)*100) + '% / judge ' + ((t.weights.judge||0)*100) + '%</div></div>';
      }
      var notes = t.notes;
      if (notes) {
        h += '<div class="ds"><div class="ds-label">Judge Notes</div>';
        h += '<div class="ds-text">' + esc(notes) + '</div></div>';
      }
      var fb = t.feedback || (t.judge && t.judge.feedback) || null;
      if (fb) {
        h += '<div class="ds"><div class="ds-label">Judge Feedback</div>';
        h += '<div class="ds-text">' + esc(fb) + '</div></div>';
      }
      if (t.judge_model) h += '<div style="font-size:0.58rem;color:var(--text-3);margin-top:2px">judge: ' + esc(t.judge_model) + '</div>';
      h += '</div></div>';
      return h;
    }

    function openPanel(key) {
      var data = allDetails[key];
      if (!data) return;
      var cls = sc(data.score);
      pTitle.textContent = data.model_id;
      var bench = data.benchmark === 'pinchbench' ? 'PinchBench' : 'ClawBench-KO';
      pMeta.innerHTML = tag('p-tag-bench', bench) + ' ' +
        tag('p-tag-date', data.date || '') + ' ' +
        '<span class="p-tag p-tag-score ' + cls + '">' + data.score.toFixed(1) + '%</span>';

      var tasks = (data.tasks||[]).slice().sort(function(a,b) {
        var aid = a.task_id || a.name || '';
        var bid = b.task_id || b.name || '';
        return aid.localeCompare(bid);
      });
      var pass = tasks.filter(function(t) { return t.score >= 80; }).length;

      var h = '<div class="panel-summary">' +
        '<span>' + tasks.length + '\uAC1C task</span>' +
        '<span style="color:var(--green);font-weight:600">' + pass + ' pass</span>' +
        '<span style="color:var(--red);font-weight:600">' + (tasks.length-pass) + ' fail</span></div>';
      tasks.forEach(function(t, i) { h += renderTask(t, i, tasks.length); });
      pBody.innerHTML = h;

      pBody.querySelectorAll('.tc-head').forEach(function(hd) {
        hd.addEventListener('click', function() {
          document.getElementById('tc-' + hd.dataset.i).classList.toggle('open');
        });
      });

      panel.classList.add('open');
      backdrop.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closePanel() {
      panel.classList.remove('open');
      backdrop.classList.remove('open');
      document.body.style.overflow = '';
    }

    rows.forEach(function(row) {
      if (!row.classList.contains('has-detail')) return;
      row.addEventListener('click', function(e) {
        if (e.target.closest('.rm-path')) return;
        if (row.dataset.detail) openPanel(row.dataset.detail);
      });
    });

    document.getElementById('panel-close').addEventListener('click', closePanel);
    backdrop.addEventListener('click', closePanel);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && panel.classList.contains('open')) closePanel();
    });
  });
</script>
