---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';

let data = { meta: {}, models: [] };
try {
  const raw = readFileSync(resolve(process.cwd(), '..', 'results', 'normalized', 'leaderboard.json'), 'utf-8');
  data = JSON.parse(raw);
} catch {}

// 히스토리 데이터가 아직 없으므로 현재 스냅샷을 단일 포인트로 표시
const models = data.models.filter(m => m.scores?.pinchbench);
const hasHistory = false; // results/normalized/history.json 생성 후 true로 전환
---

<Layout title="히스토리">
  <div class="page-header">
    <h1>성능 <span class="accent">히스토리</span></h1>
    <p>벤치마크 점수 변화를 시간 순으로 추적</p>
  </div>

  {hasHistory ? (
    <div class="card">
      <h3>PinchBench 점수 추이</h3>
      <div class="chart-container">
        <canvas id="history-chart"></canvas>
      </div>
    </div>
  ) : (
    <div class="card">
      <div class="empty-state">
        <div class="icon">⏤</div>
        <h3>아직 히스토리 데이터가 없습니다</h3>
        <p>벤치마크가 2회 이상 실행되면 시계열 차트가 여기에 표시됩니다.</p>
        <p class="hint">서버에서 <code>run-all.sh</code>를 실행하면 자동으로 히스토리가 기록됩니다.</p>
      </div>
    </div>
  )}

  {models.length > 0 && (
    <div class="card snapshot" style="margin-top:20px;">
      <h3>현재 스냅샷</h3>
      <p class="snapshot-desc">최신 측정값 (단일 시점)</p>
      <div class="snapshot-grid">
        {models.map(m => (
          <div class="snapshot-item">
            <span class="snap-name">{m.name}</span>
            <span class="snap-score">{m.scores.pinchbench.score.toFixed(1)}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="roadmap card" style="margin-top:20px;">
    <h3>히스토리 시스템 로드맵</h3>
    <div class="roadmap-list">
      <div class="rm-item pending">
        <span class="rm-dot"></span>
        <div>
          <strong>Phase 1</strong>: 벤치마크 자동화 완료 후 매 실행마다 <code>history.json</code>에 타임스탬프+점수 append
        </div>
      </div>
      <div class="rm-item pending">
        <span class="rm-dot"></span>
        <div>
          <strong>Phase 6</strong>: cron으로 주 1회 자동 실행 → 시계열 데이터 축적
        </div>
      </div>
      <div class="rm-item pending">
        <span class="rm-dot"></span>
        <div>
          <strong>시각화</strong>: Chart.js 라인 차트 — 모델별 토글, 날짜 범위 선택
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .accent { color: var(--cyan); }
  .empty-state { padding: 48px 20px; }
  .empty-state h3 { color: var(--text-2); margin-bottom: 8px; }
  .empty-state p { color: var(--text-3); font-size: 0.9rem; }
  .hint { margin-top: 8px; }
  .hint code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 2px 6px;
    background: var(--bg-elevated);
    border-radius: 4px;
    color: var(--cyan);
  }
  .snapshot-desc { font-size: 0.8rem; color: var(--text-3); margin-top: 4px; }
  .snapshot-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 12px;
    margin-top: 16px;
  }
  .snapshot-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    background: var(--bg-surface);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }
  .snap-name { font-size: 0.85rem; color: var(--text-2); }
  .snap-score {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1rem;
    color: var(--cyan);
  }
  .roadmap-list {
    display: flex; flex-direction: column; gap: 14px;
    margin-top: 14px;
  }
  .rm-item {
    display: flex; align-items: flex-start; gap: 12px;
    font-size: 0.9rem; color: var(--text-2);
  }
  .rm-item code {
    font-family: var(--font-mono); font-size: 0.85em;
    padding: 1px 5px; background: var(--bg-elevated);
    border-radius: 3px; color: var(--cyan);
  }
  .rm-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    margin-top: 5px;
    flex-shrink: 0;
    border: 2px solid var(--text-3);
    background: transparent;
  }
  .rm-item.done .rm-dot { background: var(--green); border-color: var(--green); }
</style>
