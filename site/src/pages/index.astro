---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';

let data: any = { meta: { last_updated: null, total_runs: 0, note: '' }, models: [] };
try {
  const raw = readFileSync(resolve(process.cwd(), '..', 'results', 'normalized', 'leaderboard.json'), 'utf-8');
  data = JSON.parse(raw);
} catch {}

const { meta, models } = data;

const modelCount = models.length;
const benchCount = ['pinchbench', 'clawbench_ko']
  .filter((k: string) => models.some((m: any) => m.scores?.[k])).length;
const totalRuns = meta.total_runs || 0;
const lastDate = meta.last_updated
  ? new Date(meta.last_updated).toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' })
  : '\u2014';

/* Sort by composite best for default table */
const sorted = [...models]
  .filter((m: any) => m.scores?.composite)
  .sort((a: any, b: any) => b.scores.composite.best - a.scores.composite.best);

const modelsJson = JSON.stringify(models);
---

<Layout title="리더보드">
  <div class="page-header">
    <h1>AI Agent <span class="accent">Leaderboard</span></h1>
    <p>OpenClaw 벤치마크 종합 순위 &mdash; Oracle Cloud ARM 서버 측정</p>
    {meta.note && <p class="data-notice">{meta.note}</p>}
  </div>

  <div class="stats-row">
    <div class="stat-card">
      <span class="stat-value">{modelCount}</span>
      <span class="stat-label">테스트 모델</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">{benchCount}</span>
      <span class="stat-label">벤치마크</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">{totalRuns}</span>
      <span class="stat-label">총 실행 횟수</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">{lastDate}</span>
      <span class="stat-label">최종 업데이트</span>
    </div>
  </div>

  <section class="chart-card card">
    <div class="chart-header">
      <div class="tab-bar">
        <button class="tab active" data-bench="composite">종합</button>
        <button class="tab" data-bench="pinchbench">PinchBench</button>
        <button class="tab" data-bench="clawbench_ko">ClawBench-KO</button>
      </div>
      <div class="bar-legend">
        <span class="legend-item"><span class="legend-dot best"></span> Best</span>
        <span class="legend-item"><span class="legend-dot avg"></span> Average</span>
      </div>
    </div>

    <div class="bar-chart" id="bar-chart"></div>
  </section>

  <section class="table-section">
    <h2>전체 결과</h2>
    <div class="table-wrap">
      <table id="lb-table">
        <thead>
          <tr>
            <th class="col-rank">#</th>
            <th>모델</th>
            <th>제공자</th>
            <th class="col-score">종합</th>
            <th class="col-score">PinchBench</th>
            <th class="col-score">ClawBench-KO</th>
            <th class="col-cost">비용/회</th>
          </tr>
        </thead>
        <tbody>
          {sorted.map((m: any, i: number) => (
            <tr>
              <td class="col-rank">
                <span class={`rank-badge ${i < 3 ? `top-${i+1}` : ''}`}>{i+1}</span>
              </td>
              <td>
                <div class="model-cell">
                  <span class="model-name">{m.name}</span>
                  {m.free && <span class="free-tag">FREE</span>}
                </div>
              </td>
              <td class="provider-cell">{m.provider_label}</td>
              <td class="score-mono score-best">{m.scores.composite.best.toFixed(1)}</td>
              <td class="score-mono">
                {m.scores.pinchbench
                  ? m.scores.pinchbench.best.toFixed(1)
                  : <span class="no-data">&mdash;</span>}
              </td>
              <td class="score-mono">
                {m.scores.clawbench_ko
                  ? m.scores.clawbench_ko.best.toFixed(1)
                  : <span class="no-data">&mdash;</span>}
              </td>
              <td class="cost-cell">
                {m.cost_per_run_usd === 0
                  ? <span class="free-text">$0</span>
                  : <span>${m.cost_per_run_usd.toFixed(2)}</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>

<style>
  .data-notice {
    margin-top: 6px;
    font-size: 0.78rem;
    color: var(--text-3);
    font-style: italic;
    font-family: var(--font-mono);
  }

  .chart-card {
    animation: fade-up 0.5s var(--ease-out-expo) 0.2s backwards;
  }
  .chart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 8px;
  }

  .table-section {
    margin-top: 40px;
    animation: fade-up 0.5s var(--ease-out-expo) 0.35s backwards;
  }
  .table-section h2 { margin-bottom: 16px; }
  .col-rank { width: 52px; text-align: center; }
  .col-score { min-width: 90px; }
  .col-cost { min-width: 80px; }
  td.col-rank { text-align: center; }

  @media (max-width: 768px) {
    .chart-header { flex-direction: column; align-items: flex-start; }
  }
</style>

<script is:inline define:vars={{ modelsJson }}>
  document.addEventListener('DOMContentLoaded', function() {
    var models = JSON.parse(modelsJson);

    function getScore(model, bench) {
      if (!model || !model.scores) return null;
      if (bench === 'composite') return model.scores.composite;
      return model.scores[bench];
    }

    function renderChart(bench) {
      var sorted = models
        .filter(function(m) { return getScore(m, bench); })
        .sort(function(a, b) {
          return getScore(b, bench).best - getScore(a, bench).best;
        });

      var container = document.getElementById('bar-chart');
      container.innerHTML = '';

      sorted.forEach(function(model, i) {
        var scores = getScore(model, bench);
        var delay = (i * 0.06) + 's';

        var row = document.createElement('div');
        row.className = 'bar-row';
        row.style.setProperty('--delay', delay);

        var rankClass = 'rank-badge';
        if (i < 3) rankClass += ' top-' + (i + 1);

        var freeHtml = model.free
          ? ' <span class="free-tag">FREE</span>'
          : '';

        var runsCount = (scores.runs && scores.runs.length) || 1;
        var stdVal = scores.std != null ? '\u00b1' + scores.std.toFixed(2) : '';

        var tooltipRunsHtml = '';
        if (scores.runs && scores.runs.length > 0) {
          tooltipRunsHtml = '<hr class="tooltip-divider">' +
            '<div class="tooltip-runs-title">개별 실행</div>';
          scores.runs.forEach(function(run, ri) {
            tooltipRunsHtml +=
              '<div class="tooltip-run-item">' +
                '<span class="tooltip-run-date">' + (run.date || 'Run ' + (ri+1)) + '</span>' +
                '<span class="tooltip-run-score">' + run.score.toFixed(1) + '%</span>' +
              '</div>';
          });
        }

        row.innerHTML =
          '<div class="bar-rank">' +
            '<span class="' + rankClass + '">' + (i + 1) + '</span>' +
          '</div>' +
          '<div class="bar-info">' +
            '<span class="bar-model-name">' + model.name + '</span>' +
            '<span class="bar-provider">' + model.provider_label + freeHtml + '</span>' +
          '</div>' +
          '<div class="bar-tracks">' +
            '<div class="bar-track">' +
              '<div class="bar-fill best" style="width:' + scores.best.toFixed(1) + '%">' +
                '<span class="bar-value">' + scores.best.toFixed(1) + '</span>' +
              '</div>' +
            '</div>' +
            '<div class="bar-track">' +
              '<div class="bar-fill avg" style="width:' + scores.average.toFixed(1) + '%">' +
                '<span class="bar-value">' + scores.average.toFixed(1) + '</span>' +
              '</div>' +
            '</div>' +
          '</div>' +
          '<div class="bar-tooltip">' +
            '<div class="tooltip-header">' + model.name + '</div>' +
            '<div class="tooltip-sub">' + model.provider_label + '</div>' +
            '<div class="tooltip-row"><span class="tooltip-label">Best score</span><span class="tooltip-val">' + scores.best.toFixed(1) + '%</span></div>' +
            '<div class="tooltip-row"><span class="tooltip-label">Avg score</span><span class="tooltip-val">' + scores.average.toFixed(1) + '%</span></div>' +
            (stdVal ? '<div class="tooltip-row"><span class="tooltip-label">Std</span><span class="tooltip-val">' + stdVal + '</span></div>' : '') +
            '<div class="tooltip-row"><span class="tooltip-label">Runs</span><span class="tooltip-val">' + runsCount + '</span></div>' +
            tooltipRunsHtml +
          '</div>';

        container.appendChild(row);
      });
    }

    /* initial render */
    renderChart('composite');

    /* tab switching */
    var tabs = document.querySelectorAll('.tab');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        renderChart(tab.dataset.bench);
      });
    });

    /* table sorting */
    var table = document.getElementById('lb-table');
    if (!table) return;
    var headers = table.querySelectorAll('th');
    var sortCol = 3;
    var sortAsc = false;

    headers.forEach(function(th, idx) {
      th.addEventListener('click', function() {
        if (sortCol === idx) { sortAsc = !sortAsc; }
        else { sortCol = idx; sortAsc = idx <= 2; }

        headers.forEach(function(h) {
          h.classList.remove('sorted');
          var a = h.querySelector('.sort-arrow');
          if (a) a.remove();
        });
        th.classList.add('sorted');
        var arrow = document.createElement('span');
        arrow.className = 'sort-arrow';
        arrow.textContent = sortAsc ? ' \u25B2' : ' \u25BC';
        th.appendChild(arrow);

        var tbody = table.querySelector('tbody');
        var rows = Array.from(tbody.querySelectorAll('tr'));

        rows.sort(function(a, b) {
          var cellA = a.cells[idx];
          var cellB = b.cells[idx];
          var va, vb;

          if (idx === 0) {
            va = parseInt(cellA.textContent);
            vb = parseInt(cellB.textContent);
          } else if (idx <= 2) {
            va = cellA.textContent.trim();
            vb = cellB.textContent.trim();
            return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
          } else {
            va = parseFloat(cellA.textContent.replace('$', '')) || -1;
            vb = parseFloat(cellB.textContent.replace('$', '')) || -1;
          }
          return sortAsc ? va - vb : vb - va;
        });

        rows.forEach(function(r) { tbody.appendChild(r); });
      });
    });
  });
</script>
